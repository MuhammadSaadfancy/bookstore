@model List<BookStore.Models.Faqs>

@{
    ViewData["Title"] = "Frequently Asked Questions";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <h1 class="text-center mb-4">
        <i class="fas fa-question-circle text-primary me-2"></i>Frequently Asked Questions
    </h1>

    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="accordion" id="faqAccordion">
                @for (int i = 0; i < Model.Count; i++)
                {
                    var faq = Model[i];
                    <div class="accordion-item">
                        <h2 class="accordion-header" id="heading@(i)">
                            <button class="accordion-button @(i > 0 ? "collapsed" : "")"
                                    type="button" data-bs-toggle="collapse"
                                    data-bs-target="#collapse@(i)"
                                    aria-expanded="@(i == 0 ? "true" : "false")"
                                    aria-controls="collapse@(i)">
                                <i class="fas fa-question me-3 text-primary"></i>
                                @faq.faqs_Question
                            </button>
                        </h2>
                        <div id="collapse@(i)"
                             class="accordion-collapse collapse @(i == 0 ? "show" : "")"
                             aria-labelledby="heading@(i)"
                             data-bs-parent="#faqAccordion">
                            <div class="accordion-body">
                                <i class="fas fa-lightbulb me-2 text-warning"></i>
                                @faq.faqs_Answer
                            </div>
                        </div>
                    </div>
                }
            </div>

            @if (!Model.Any())
            {
                <div class="alert alert-info text-center">
                    <i class="fas fa-info-circle fa-2x mb-3"></i>
                    <h4>No FAQs available at the moment.</h4>
                    <p>Please check back later or contact our support team.</p>
                </div>
            }

            <div class="card mt-5">
                <div class="card-body text-center">
                    <h5 class="card-title">Still have questions?</h5>
                    <p class="card-text">Can't find what you're looking for? Contact our support team.</p>
                    <div class="mt-3">
                        <a href="/Contact" class="btn btn-primary me-2">
                            <i class="fas fa-headset me-1"></i> Contact Support
                        </a>
                        <a href="/" class="btn btn-outline-secondary">
                            <i class="fas fa-home me-1"></i> Back to Home
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>