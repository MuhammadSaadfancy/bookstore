@model BookStore.Models.Order

@{
    ViewData["Title"] = "Order Status";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Add custom CSS for the order status page -->
<style>
    /* Custom styling for order status page */
    .order-status-page {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        background: linear-gradient(135deg, #f8f9fa 0%, #e8f4f8 100%);
        min-height: calc(100vh - 120px);
        padding-top: 2rem;
        position: relative;
        overflow: hidden;
    }

        /* Background decorative elements */
        .order-status-page::before {
            content: "";
            position: absolute;
            top: 10%;
            right: 5%;
            width: 300px;
            height: 300px;
            background: radial-gradient(circle, rgba(52, 152, 219, 0.1) 0%, transparent 70%);
            border-radius: 50%;
            z-index: 0;
        }

        .order-status-page::after {
            content: "";
            position: absolute;
            bottom: 15%;
            left: 5%;
            width: 200px;
            height: 200px;
            background: radial-gradient(circle, rgba(46, 204, 113, 0.1) 0%, transparent 70%);
            border-radius: 50%;
            z-index: 0;
        }

        .order-status-page h1 {
            color: #2c3e50;
            font-weight: 800;
            position: relative;
            padding-bottom: 15px;
            margin-bottom: 2.5rem;
            letter-spacing: 1px;
            text-shadow: 1px 1px 3px rgba(0, 0, 0, 0.1);
            font-size: 2.8rem;
            background: linear-gradient(135deg, #2c3e50, #3498db);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

            .order-status-page h1::after {
                content: "";
                position: absolute;
                bottom: 0;
                left: 50%;
                transform: translateX(-50%);
                width: 150px;
                height: 4px;
                background: linear-gradient(90deg, #3498db, #2ecc71, #3498db);
                border-radius: 2px;
                background-size: 200% 100%;
                animation: gradientShift 3s ease infinite;
            }

    @@keyframes gradientShift {
        0% {
            background-position: 0% 50%;
        }

        50% {
            background-position: 100% 50%;
        }

        100% {
            background-position: 0% 50%;
        }
    }

    /* Main order card */
    .order-status-page .card {
        border-radius: 25px;
        border: none;
        overflow: hidden;
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        box-shadow: 0 25px 50px rgba(52, 152, 219, 0.2);
        margin-bottom: 2.5rem;
        animation: cardAppear 0.8s ease-out;
        position: relative;
        z-index: 1;
        border: 1px solid rgba(255, 255, 255, 0.3);
    }

    @@keyframes cardAppear {
        from {
            opacity: 0;
            transform: translateY(30px) scale(0.95);
        }

        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    /* Order header */
    .order-status-page .card-header {
        background: linear-gradient(135deg, #3498db, #2ecc71);
        border-bottom: none;
        padding: 2rem;
        position: relative;
        overflow: hidden;
    }

        .order-status-page .card-header::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.15), transparent);
            animation: shimmer 3s infinite linear;
        }

    @@keyframes shimmer {
        0% {
            transform: translateX(-100%);
        }

        100% {
            transform: translateX(100%);
        }
    }

    .order-status-page .card-header h4 {
        font-weight: 700;
        font-size: 2rem;
        margin: 0;
        position: relative;
        z-index: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        text-shadow: 1px 1px 3px rgba(0, 0, 0, 0.2);
    }

        .order-status-page .card-header h4::before {
            content: "📦";
            margin-right: 15px;
            font-size: 2.2rem;
            animation: float 3s ease-in-out infinite;
        }

    @@keyframes float {
        0%, 100% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-10px);
        }
    }

    /* Order details grid */
    .order-details-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1.8rem;
        margin-bottom: 2.5rem;
        padding: 0 0.5rem;
    }

    .detail-card {
        background: linear-gradient(145deg, #ffffff, #f5f9ff);
        padding: 1.8rem;
        border-radius: 18px;
        border: 1px solid rgba(52, 152, 219, 0.1);
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        position: relative;
        overflow: hidden;
        box-shadow: 0 8px 20px rgba(0, 0, 0, 0.05);
    }

        .detail-card:hover {
            transform: translateY(-8px) scale(1.02);
            box-shadow: 0 15px 30px rgba(52, 152, 219, 0.15);
            border-color: rgba(52, 152, 219, 0.3);
        }

        .detail-card::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 5px;
            height: 100%;
            background: linear-gradient(to bottom, #3498db, #2ecc71);
            transition: width 0.3s ease;
        }

        .detail-card:hover::before {
            width: 8px;
        }

        .detail-card strong {
            color: #2c3e50;
            display: block;
            margin-bottom: 10px;
            font-size: 1rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #3498db;
            font-weight: 700;
            display: flex;
            align-items: center;
        }

            .detail-card strong::before {
                content: "";
                display: inline-block;
                width: 8px;
                height: 8px;
                background: #3498db;
                border-radius: 50%;
                margin-right: 10px;
                animation: pulseDot 2s infinite;
            }

    @@keyframes pulseDot {
        0%, 100% {
            transform: scale(1);
            opacity: 1;
        }

        50% {
            transform: scale(1.3);
            opacity: 0.7;
        }
    }

    .detail-card p {
        color: #555;
        font-size: 1.3rem;
        font-weight: 600;
        margin: 0;
        line-height: 1.4;
    }

    /* Special styling for status card */
    .status-card {
        grid-column: span 2;
        background: linear-gradient(145deg, #ffffff, #f0fff4);
        border-color: rgba(46, 204, 113, 0.2);
    }

        .status-card strong::before {
            background: #2ecc71;
        }

    /* Status badge styling */
    .status-badge {
        display: inline-flex;
        align-items: center;
        padding: 0.8rem 1.5rem;
        font-size: 1.1rem;
        font-weight: 700;
        border-radius: 50px;
        text-transform: uppercase;
        letter-spacing: 1px;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
        animation: badgeGlow 2s infinite;
        position: relative;
        overflow: hidden;
    }

    @@keyframes badgeGlow {
        0%, 100% {
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
        }

        50% {
            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.2);
        }
    }

    .status-badge::before {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
        animation: shimmer 2s infinite linear;
    }

    .status-delivered {
        background: linear-gradient(135deg, #2ecc71, #27ae60);
        color: white;
    }

    .status-pending {
        background: linear-gradient(135deg, #f39c12, #e67e22);
        color: white;
    }

    .status-processing {
        background: linear-gradient(135deg, #3498db, #2980b9);
        color: white;
    }

    /* Order summary section */
    .order-summary {
        background: linear-gradient(135deg, rgba(52, 152, 219, 0.05), rgba(46, 204, 113, 0.05));
        border-radius: 20px;
        padding: 2.5rem;
        margin: 2.5rem 0;
        border: 1px solid rgba(52, 152, 219, 0.1);
        position: relative;
        overflow: hidden;
    }

        .order-summary::before {
            content: "🎯";
            position: absolute;
            top: 20px;
            right: 20px;
            font-size: 3rem;
            opacity: 0.1;
        }

        .order-summary h3 {
            color: #2c3e50;
            font-weight: 700;
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
        }

            .order-summary h3::before {
                content: "✨";
                margin-right: 10px;
                font-size: 1.5rem;
            }

    .summary-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1.5rem;
    }

    .summary-item {
        text-align: center;
        padding: 1.5rem;
        background: white;
        border-radius: 15px;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
        transition: all 0.3s ease;
    }

        .summary-item:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0, 0, 0, 0.1);
        }

        .summary-item .label {
            color: #7f8c8d;
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 8px;
        }

        .summary-item .value {
            color: #2c3e50;
            font-size: 1.8rem;
            font-weight: 800;
            color: #3498db;
        }

    /* Back button styling */
    .back-btn-container {
        text-align: center;
        margin-top: 3rem;
        position: relative;
        z-index: 1;
    }

    .order-status-page .btn-primary {
        background: linear-gradient(135deg, #3498db, #2ecc71);
        border: none;
        border-radius: 50px;
        padding: 1.2rem 3rem;
        font-weight: 700;
        font-size: 1.2rem;
        letter-spacing: 1px;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        position: relative;
        overflow: hidden;
        z-index: 1;
        box-shadow: 0 10px 20px rgba(52, 152, 219, 0.3);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }

        .order-status-page .btn-primary::before {
            content: "";
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
            transition: all 0.8s ease;
            z-index: -1;
        }

        .order-status-page .btn-primary:hover {
            transform: translateY(-5px) scale(1.05);
            box-shadow: 0 15px 30px rgba(52, 152, 219, 0.4);
            background: linear-gradient(135deg, #2980b9, #27ae60);
        }

            .order-status-page .btn-primary:hover::before {
                left: 100%;
            }

        .order-status-page .btn-primary:active {
            transform: translateY(0) scale(1);
        }

        .order-status-page .btn-primary::after {
            content: "🏠";
            font-size: 1.3rem;
        }

    /* Responsive adjustments */
    @@media (max-width: 992px) {
        .status-card {
            grid-column: span 1;
        }

        .summary-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 768px) {
        .order-status-page .card-body {
            padding: 2rem;
        }

        .order-status-page h1 {
            font-size: 2.2rem;
        }

        .order-status-page .card-header h4 {
            font-size: 1.6rem;
        }

        .order-details-grid {
            grid-template-columns: 1fr;
        }

        .summary-grid {
            grid-template-columns: 1fr;
        }

        .order-status-page::before,
        .order-status-page::after {
            display: none;
        }
    }

    @@media (max-width: 576px) {
        .order-status-page {
            padding-top: 1rem;
        }

            .order-status-page .card-body {
                padding: 1.5rem;
            }

            .order-status-page h1 {
                font-size: 1.8rem;
                margin-bottom: 2rem;
            }

            .order-status-page .btn-primary {
                padding: 1rem 2.5rem;
                font-size: 1.1rem;
                width: 100%;
                max-width: 300px;
            }

        .detail-card {
            padding: 1.5rem;
        }

        .order-summary {
            padding: 1.8rem;
        }
    }

    /* Container specific styling */
    .order-status-page .container {
        position: relative;
        z-index: 1;
    }
</style>

<div class="order-status-page">
    <div class="container py-5">
        <h1 class="mb-4 text-center">Order Status</h1>

        <div class="card shadow">
            <div class="card-header bg-info text-white">
                <h4>Order Number: @Model.OrderNumber</h4>
            </div>
            <div class="card-body">
                <!-- Order details in enhanced grid layout -->
                <div class="order-details-grid">
                    <div class="detail-card">
                        <strong>Order Date</strong>
                        <p>@Model.OrderDate.ToString("dd MMMM yyyy")</p>
                    </div>

                    <div class="detail-card status-card">
                        <strong>Status</strong>
                        <div class="mt-3">
                            <span class="status-badge
                                @(Model.OrderStatus == "Delivered" ? "status-delivered" :
                                                                    Model.OrderStatus == "Pending" ? "status-pending" : "status-processing")">
                                @Model.OrderStatus
                            </span>
                        </div>
                    </div>

                    <div class="detail-card">
                        <strong>Total Amount</strong>
                        <p>Rs. @Model.TotalAmount</p>
                    </div>

                    <div class="detail-card">
                        <strong>Shipping Address</strong>
                        <p>@Model.ShippingAddress</p>
                    </div>
                </div>

                <!-- Order Summary Section -->
                <div class="order-summary">
                    <h3>Order Summary</h3>
                    <div class="summary-grid">
                        <div class="summary-item">
                            <div class="label">Order Number</div>
                            <div class="value">@Model.OrderNumber</div>
                        </div>
                        <div class="summary-item">
                            <div class="label">Items Count</div>
                            <div class="value">@Model.OrderItems.Count</div>
                        </div>
                        <div class="summary-item">
                            <div class="label">Order Date</div>
                            <div class="value">@Model.OrderDate.ToString("dd/MM")</div>
                        </div>
                        <div class="summary-item">
                            <div class="label">Status</div>
                            <div class="value">@Model.OrderStatus</div>
                        </div>
                    </div>
                </div>

                <!-- Status Timeline (Optional Visual Element) -->
                <div class="text-center mt-4">
                    <p class="text-muted">
                        <i class="fas fa-clock me-2"></i>
                        Last updated: @DateTime.Now.ToString("hh:mm tt")
                    </p>
                </div>
            </div>
        </div>

        <div class="back-btn-container">
            <a href="/" class="btn btn-primary">Back to Home</a>
        </div>
    </div>
</div>