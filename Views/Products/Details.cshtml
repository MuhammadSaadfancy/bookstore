@model BookStore.Models.Product

@{
    ViewData["Title"] = Model.product_name;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* Product Details Page Styling */
    .product-detail-page {
        background: linear-gradient(135deg, #f8f9fa 0%, #f1f5f9 100%);
        min-height: 100vh;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

        .product-detail-page .container {
            padding-top: 3rem;
            padding-bottom: 3rem;
        }

        .product-detail-page .row {
            background: white;
            border-radius: 24px;
            overflow: hidden;
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.08);
            min-height: 600px;
            margin: 0;
        }

        /* Product Image Section */
        .product-detail-page .col-md-5 {
            padding: 3rem;
            background: linear-gradient(135deg, #f8fafc, #ffffff);
            display: flex;
            align-items: center;
            justify-content: center;
            border-right: 1px solid #e2e8f0;
            position: relative;
        }

            .product-detail-page .col-md-5::before {
                content: "";
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 5px;
                background: linear-gradient(90deg, #6366f1, #10b981);
            }

        .product-detail-page .img-fluid {
            max-height: 500px;
            width: auto;
            border-radius: 16px;
            box-shadow: 0 15px 30px rgba(0, 0, 0, 0.1);
            transition: all 0.3s ease;
            border: 1px solid #e2e8f0;
        }

            .product-detail-page .img-fluid:hover {
                transform: scale(1.02);
                box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
            }

        /* Product Info Section */
        .product-detail-page .col-md-7 {
            padding: 3rem;
            background: white;
            display: flex;
            flex-direction: column;
        }

        /* Product Title */
        .product-detail-page h1 {
            color: #1e293b;
            font-weight: 800;
            font-size: 2.5rem;
            margin-bottom: 1.5rem;
            line-height: 1.2;
            position: relative;
            padding-bottom: 15px;
        }

            .product-detail-page h1::after {
                content: "";
                position: absolute;
                bottom: 0;
                left: 0;
                width: 80px;
                height: 4px;
                background: linear-gradient(90deg, #6366f1, #10b981);
                border-radius: 2px;
            }

        /* Price Styling */
        .product-detail-page h3.text-primary {
            color: #059669 !important;
            font-weight: 800;
            font-size: 2.2rem;
            margin-bottom: 2rem;
            background: linear-gradient(135deg, #059669, #10b981);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            padding: 0.5rem 1rem;
            background-color: rgba(16, 185, 129, 0.1);
            border-radius: 12px;
            display: inline-block;
        }

        /* Product Details Grid */
        .product-detail-page p {
            margin-bottom: 1.2rem;
            font-size: 1.1rem;
            color: #475569;
            padding: 0.8rem 1rem;
            background: #f8fafc;
            border-radius: 10px;
            border-left: 4px solid #6366f1;
            transition: all 0.3s ease;
        }

            .product-detail-page p:hover {
                transform: translateX(5px);
                background: white;
                box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
            }

            .product-detail-page p strong {
                color: #334155;
                font-weight: 700;
                min-width: 140px;
                display: inline-block;
            }

            /* Description Section */
            .product-detail-page p.mt-4 {
                background: linear-gradient(135deg, #f0f9ff, #f8fafc);
                padding: 1.5rem;
                border-radius: 16px;
                border-left: 4px solid #10b981;
                line-height: 1.6;
                font-size: 1.05rem;
                margin-top: 2rem;
                color: #4b5563;
            }

                .product-detail-page p.mt-4 strong {
                    color: #059669;
                    font-size: 1.1rem;
                    margin-bottom: 0.5rem;
                    display: block;
                }

        /* Add to Cart Form */
        .product-detail-page .mt-5 {
            margin-top: auto;
            padding-top: 2rem;
            border-top: 2px solid #f1f5f9;
        }

        .product-detail-page form {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .product-detail-page .btn-success {
            background: linear-gradient(135deg, #059669, #10b981);
            border: none;
            border-radius: 12px;
            padding: 1.2rem 2.5rem;
            font-weight: 700;
            font-size: 1.2rem;
            transition: all 0.3s ease;
            box-shadow: 0 10px 20px rgba(16, 185, 129, 0.2);
            display: flex;
            align-items: center;
            gap: 10px;
            min-width: 220px;
        }

            .product-detail-page .btn-success:hover {
                transform: translateY(-3px);
                box-shadow: 0 15px 30px rgba(16, 185, 129, 0.3);
                background: linear-gradient(135deg, #047857, #0da271);
            }

            .product-detail-page .btn-success:active {
                transform: translateY(0);
            }

            .product-detail-page .btn-success i {
                font-size: 1.3rem;
                animation: cartFloat 2s ease-in-out infinite;
            }

    @@keyframes cartFloat {
        0%, 100% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-3px);
        }
    }

    /* Responsive Design */
    @@media (max-width: 992px) {
        .product-detail-page .row {
            flex-direction: column;
        }

        .product-detail-page .col-md-5 {
            border-right: none;
            border-bottom: 1px solid #e2e8f0;
            padding: 2rem;
        }

        .product-detail-page .col-md-7 {
            padding: 2.5rem;
        }

        .product-detail-page .img-fluid {
            max-height: 400px;
        }
    }

    @@media (max-width: 768px) {
        .product-detail-page .container {
            padding-top: 2rem;
            padding-bottom: 2rem;
        }

        .product-detail-page h1 {
            font-size: 2rem;
        }

        .product-detail-page h3.text-primary {
            font-size: 1.8rem;
        }

        .product-detail-page .col-md-5,
        .product-detail-page .col-md-7 {
            padding: 2rem;
        }

        .product-detail-page .btn-success {
            padding: 1rem 2rem;
            font-size: 1.1rem;
            min-width: 200px;
        }
    }

    @@media (max-width: 576px) {
        .product-detail-page h1 {
            font-size: 1.8rem;
        }

        .product-detail-page h3.text-primary {
            font-size: 1.6rem;
        }

        .product-detail-page p {
            font-size: 1rem;
            padding: 0.7rem 0.9rem;
        }

        .product-detail-page .col-md-5,
        .product-detail-page .col-md-7 {
            padding: 1.5rem;
        }

        .product-detail-page .btn-success {
            width: 100%;
            justify-content: center;
        }

        .product-detail-page form {
            flex-direction: column;
            gap: 1rem;
        }
    }

    /* Ensure columns fill space */
    .product-detail-page .col-md-5,
    .product-detail-page .col-md-7 {
        flex: 1;
    }
</style>

<div class="product-detail-page">
    <div class="container py-5">
        <div class="row">
            <!-- Product Image -->
            <div class="col-md-5">
                <img src="@(Model.product_image ?? "/images/placeholder.jpg")"
                     class="img-fluid rounded shadow"
                     alt="@Model.product_name">
            </div>

            <!-- Product Info -->
            <div class="col-md-7">
                <h1 class="mb-3">@Model.product_name</h1>
                <h3 class="text-primary mb-4">Rs. @Model.product_price</h3>

                <p><strong>Category:</strong> @(Model.Category?.Category_Name ?? "Uncategorized")</p>

                @if (!string.IsNullOrEmpty(Model.Author))
                {
                    <p><strong>Author:</strong> @Model.Author</p>
                }

                @if (!string.IsNullOrEmpty(Model.Publisher))
                {
                    <p><strong>Publisher:</strong> @Model.Publisher</p>
                }

                @if (Model.ReleaseDate.HasValue)
                {
                    <p><strong>Release Date:</strong> @Model.ReleaseDate.Value.ToString("dd MMMM yyyy")</p>
                }

                <p class="mt-4">
                    <strong>Description:</strong><br />
                    @Model.product_description
                </p>

                <!-- Add to Cart Button -->
                <div class="mt-5">
                    <form asp-controller="Cart" asp-action="AddToCart" method="post">
                        <input type="hidden" name="prod_id" value="@Model.product_id" />
                        <input type="hidden" name="quantity" value="1" />
                        <button type="submit" class="btn btn-success btn-lg">
                            <i class="fas fa-cart-plus"></i> Add to Cart
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>