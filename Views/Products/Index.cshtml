@model List<BookStore.Models.Product>

@{
    ViewData["Title"] = "All Products";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* All Products Page Styling */
    .all-products-page {
        background: linear-gradient(135deg, #f8f9fa 0%, #f1f5f9 100%);
        min-height: 100vh;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

        .all-products-page .container {
            padding-top: 3rem;
            padding-bottom: 5rem;
        }

        /* Page Header */
        .all-products-page h1 {
            color: #1e293b;
            font-weight: 800;
            font-size: 2.8rem;
            margin-bottom: 2.5rem;
            text-align: center;
            position: relative;
            padding-bottom: 15px;
            text-shadow: 1px 1px 3px rgba(0, 0, 0, 0.05);
        }

            .all-products-page h1::after {
                content: "";
                position: absolute;
                bottom: 0;
                left: 50%;
                transform: translateX(-50%);
                width: 120px;
                height: 4px;
                background: linear-gradient(90deg, #6366f1, #10b981);
                border-radius: 2px;
            }

        /* Product Grid */
        .all-products-page .row {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 2rem;
            margin: 0;
        }

        /* Product Card */
        .all-products-page .card {
            background: white;
            border-radius: 20px;
            border: none;
            overflow: hidden;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.08);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            height: 100%;
            position: relative;
            display: flex;
            flex-direction: column;
        }

            .all-products-page .card:hover {
                transform: translateY(-10px) scale(1.02);
                box-shadow: 0 20px 40px rgba(99, 102, 241, 0.15);
            }

            .all-products-page .card::before {
                content: "";
                position: absolute;
                top: 0;
                left: 0;
                width: 100%;
                height: 4px;
                background: linear-gradient(90deg, #6366f1, #10b981);
                z-index: 2;
            }

        /* Product Image */
        .all-products-page .card-img-top {
            height: 250px;
            object-fit: cover;
            width: 100%;
            border-bottom: 1px solid #e2e8f0;
            transition: transform 0.5s ease;
        }

        .all-products-page .card:hover .card-img-top {
            transform: scale(1.05);
        }

        /* Card Body */
        .all-products-page .card-body {
            padding: 1.8rem;
            display: flex;
            flex-direction: column;
            flex-grow: 1;
            background: linear-gradient(135deg, #ffffff, #f8fafc);
        }

        /* Product Title */
        .all-products-page .card-title {
            color: #1e293b;
            font-weight: 700;
            font-size: 1.3rem;
            margin-bottom: 0.8rem;
            line-height: 1.4;
            min-height: 56px;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        /* Price Styling */
        .all-products-page .text-primary {
            color: #059669 !important;
            font-weight: 800;
            font-size: 1.5rem;
            margin-bottom: 0.5rem;
            background: linear-gradient(135deg, #059669, #10b981);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            display: inline-block;
            padding: 0.3rem 0.8rem;
            background-color: rgba(16, 185, 129, 0.1);
            border-radius: 8px;
        }

        /* Category Tag */
        .all-products-page .text-muted.small {
            color: #64748b !important;
            font-size: 0.9rem;
            font-weight: 600;
            margin-bottom: 1.2rem;
            padding: 0.4rem 0.8rem;
            background: rgba(99, 102, 241, 0.08);
            border-radius: 20px;
            display: inline-block;
            border: 1px solid rgba(99, 102, 241, 0.1);
        }

        /* View Details Button */
        .all-products-page .btn-outline-primary {
            color: #6366f1;
            border: 2px solid #6366f1;
            border-radius: 10px;
            padding: 0.6rem 1.5rem;
            font-weight: 600;
            font-size: 0.95rem;
            transition: all 0.3s ease;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-top: auto;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

            .all-products-page .btn-outline-primary:hover {
                background: linear-gradient(135deg, #6366f1, #8b5cf6);
                color: white;
                border-color: #6366f1;
                transform: translateY(-2px);
                box-shadow: 0 5px 15px rgba(99, 102, 241, 0.2);
            }

            .all-products-page .btn-outline-primary::after {
                content: "→";
                font-weight: bold;
                transition: transform 0.3s ease;
            }

            .all-products-page .btn-outline-primary:hover::after {
                transform: translateX(3px);
            }

    /* Card Animation */
    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .all-products-page .col-md-3 {
        animation: fadeInUp 0.6s ease-out forwards;
        opacity: 0;
    }

        /* Stagger animations for grid items */
        .all-products-page .col-md-3:nth-child(1) {
            animation-delay: 0.1s;
        }

        .all-products-page .col-md-3:nth-child(2) {
            animation-delay: 0.2s;
        }

        .all-products-page .col-md-3:nth-child(3) {
            animation-delay: 0.3s;
        }

        .all-products-page .col-md-3:nth-child(4) {
            animation-delay: 0.4s;
        }

        .all-products-page .col-md-3:nth-child(5) {
            animation-delay: 0.5s;
        }

        .all-products-page .col-md-3:nth-child(6) {
            animation-delay: 0.6s;
        }

        .all-products-page .col-md-3:nth-child(7) {
            animation-delay: 0.7s;
        }

        .all-products-page .col-md-3:nth-child(8) {
            animation-delay: 0.8s;
        }

    /* Empty State */
    .all-products-page .empty-state {
        text-align: center;
        padding: 4rem 2rem;
        background: white;
        border-radius: 20px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
    }

        .all-products-page .empty-state h3 {
            color: #64748b;
            font-weight: 600;
            margin-bottom: 1rem;
        }

    /* Responsive Design */
    @@media (max-width: 1200px) {
        .all-products-page .row {
            grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
            gap: 1.5rem;
        }
    }

    @@media (max-width: 768px) {
        .all-products-page .container {
            padding-top: 2rem;
            padding-bottom: 3rem;
        }

        .all-products-page h1 {
            font-size: 2.2rem;
            margin-bottom: 2rem;
        }

        .all-products-page .row {
            grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
            gap: 1.5rem;
        }

        .all-products-page .card-img-top {
            height: 200px;
        }

        .all-products-page .card-title {
            font-size: 1.2rem;
            min-height: 52px;
        }

        .all-products-page .text-primary {
            font-size: 1.3rem;
        }
    }

    @@media (max-width: 576px) {
        .all-products-page h1 {
            font-size: 1.8rem;
        }

        .all-products-page .row {
            grid-template-columns: 1fr;
            gap: 1.5rem;
            max-width: 350px;
            margin: 0 auto;
        }

        .all-products-page .card-body {
            padding: 1.5rem;
        }

        .all-products-page .btn-outline-primary {
            padding: 0.7rem 1.5rem;
            font-size: 1rem;
        }
    }

    /* Grid Container */
    .all-products-page .col-md-3 {
        width: 100%;
        padding: 0;
    }

    /* Ensure equal height cards */
    .all-products-page .card {
        height: 100%;
        display: flex;
        flex-direction: column;
    }

    .all-products-page .card-body {
        flex-grow: 1;
    }
</style>

<div class="all-products-page">
    <div class="container py-5">
        <h1 class="mb-4">All Products</h1>

        <div class="row">
            @foreach (var product in Model)
            {
                <div class="col-md-3 col-sm-6 mb-4">
                    <div class="card h-100 border-0 shadow-sm">
                        <img src="@(product.product_image ?? "/images/placeholder.jpg")"
                             class="card-img-top"
                             alt="@product.product_name"
                             style="height: 220px; object-fit: cover;">
                        <div class="card-body text-center">
                            <h5 class="card-title">@product.product_name</h5>
                            <p class="text-primary fw-bold">Rs. @product.product_price</p>
                            <p class="text-muted small">@(product.Category?.Category_Name ?? "Uncategorized")</p>
                            <a href="@Url.Action("Details", new { id = product.product_id })"
                               class="btn btn-sm btn-outline-primary">View Details</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>