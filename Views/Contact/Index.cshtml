@{
    ViewData["Title"] = "Contact Us";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="text-center mb-5">
                <h1 class="display-5 fw-bold text-primary">
                    <i class="fas fa-headset me-2"></i>Contact Us
                </h1>
                <p class="lead">Have questions? We're here to help!</p>
            </div>

            <div class="row">
                <div class="col-md-5 mb-4">
                    <div class="card shadow h-100 border-0">
                        <div class="card-body p-4">
                            <h4 class="card-title mb-4">
                                <i class="fas fa-map-marker-alt text-primary me-2"></i>Our Location
                            </h4>
                            <div class="mb-4">
                                <h6 class="fw-bold">Head Office</h6>
                                <p class="mb-2">
                                    <i class="fas fa-building me-2 text-secondary"></i>
                                    Shradha Book Stores Building
                                </p>
                                <p class="mb-0">
                                    <i class="fas fa-location-dot me-2 text-secondary"></i>
                                    Main University Road, Karachi, Pakistan
                                </p>
                            </div>

                            <h5 class="mb-3">
                                <i class="fas fa-phone-volume text-primary me-2"></i>Contact Info
                            </h5>
                            <ul class="list-unstyled">
                                <li class="mb-3">
                                    <i class="fas fa-phone me-2 text-success"></i>
                                    <strong>Phone:</strong> 0312-1234567
                                </li>
                                <li class="mb-3">
                                    <i class="fas fa-envelope me-2 text-danger"></i>
                                    <strong>Email:</strong> info@shradhabookstores.com
                                </li>
                                <li class="mb-3">
                                    <i class="fas fa-clock me-2 text-warning"></i>
                                    <strong>Hours:</strong> 9:00 AM - 8:00 PM (Mon-Sat)
                                </li>
                                <li>
                                    <i class="fas fa-calendar me-2 text-info"></i>
                                    <strong>Closed:</strong> Sundays & Public Holidays
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>

                <div class="col-md-7">
                    <div class="card shadow border-0">
                        <div class="card-body p-4">
                            <h4 class="card-title mb-4">
                                <i class="fas fa-paper-plane text-primary me-2"></i>Send Message
                            </h4>

                            <form id="contactForm" method="post" asp-action="SendMessage">
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">Your Name *</label>
                                        <input type="text" name="name" class="form-control"
                                               placeholder="Enter your name" required>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label">Your Email *</label>
                                        <input type="email" name="email" class="form-control"
                                               placeholder="Enter your email" required>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">Subject</label>
                                    <input type="text" name="subject" class="form-control"
                                           placeholder="Subject of your message">
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">Your Message *</label>
                                    <textarea name="message" class="form-control" rows="5"
                                              placeholder="How can we help you?" required></textarea>
                                </div>

                                <div class="d-grid">
                                    <button type="submit" class="btn btn-primary btn-lg">
                                        <i class="fas fa-paper-plane me-2"></i>Send Message
                                    </button>
                                </div>
                            </form>

                            <div class="mt-4 text-center">
                                <p class="text-muted">
                                    <i class="fas fa-info-circle me-1"></i>
                                    We usually respond within 24 hours
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Map Section (Optional) -->
            <div class="card shadow border-0 mt-4">
                <div class="card-body p-0">
                    <div class="map-container" style="height: 300px; background: #e9ecef;
                         display: flex; align-items: center; justify-content: center;">
                        <div class="text-center">
                            <i class="fas fa-map-marked-alt fa-3x text-secondary mb-3"></i>
                            <h5>Karachi Location Map</h5>
                            <p class="mb-0">(Map integration available)</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Contact form validation
        $(document).ready(function() {
            $('#contactForm').on('submit', function(e) {
                // Add custom validation if needed
            });
        });
    </script>
}