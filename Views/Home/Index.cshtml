@model List<BookStore.Models.Product>
@{
    ViewData["Title"] = "Shradha Book Stores";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* Home Page Styling - Categories Original */
    .home-page {
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        overflow-x: hidden;
    }

    /* Hero Section with Animation */
    .hero {
        position: relative;
        background: linear-gradient(rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.7)), url('https://images.unsplash.com/photo-1497633762265-9d179a990aa6?ixlib=rb-4.0.3&auto=format&fit=crop&w=1350&q=80') !important;
        background-size: cover !important;
        background-position: center !important;
        min-height: 85vh;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

        /* Hero Content Animation - SLIDE UP FROM BOTTOM */
        .hero .container {
            position: relative;
            z-index: 2;
            max-width: 800px;
            animation: slideUp 1.2s ease-out forwards;
            opacity: 0;
            transform: translateY(50px);
        }

    @@keyframes slideUp {
        0% {
            opacity: 0;
            transform: translateY(50px);
        }

        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Hero Text Animation */
    .hero h1 {
        font-size: 3.5rem;
        font-weight: 800;
        margin-bottom: 1.5rem;
        color: white;
        text-shadow: 2px 2px 8px rgba(0, 0, 0, 0.5);
        line-height: 1.2;
        animation: fadeIn 1.5s ease-out 0.3s forwards;
        opacity: 0;
    }

    .hero p.lead {
        font-size: 1.5rem;
        margin-bottom: 2.5rem;
        color: #f1f5f9;
        text-shadow: 1px 1px 4px rgba(0, 0, 0, 0.5);
        animation: fadeIn 1.5s ease-out 0.6s forwards;
        opacity: 0;
    }

    .hero .btn-primary {
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        border: none;
        border-radius: 50px;
        padding: 1.2rem 3rem;
        font-size: 1.3rem;
        font-weight: 700;
        transition: all 0.3s ease;
        animation: fadeIn 1.5s ease-out 0.9s forwards;
        opacity: 0;
        position: relative;
        overflow: hidden;
    }

        .hero .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(99, 102, 241, 0.4);
        }

        .hero .btn-primary::before {
            content: "📚";
            margin-right: 10px;
            animation: bookFloat 2s ease-in-out infinite;
        }

    @@keyframes bookFloat {
        0%, 100% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-5px);
        }
    }

    @@keyframes fadeIn {
        0% {
            opacity: 0;
            transform: translateY(20px);
        }

        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Featured Products with Staggered Animation */
    .bg-light {
        background: #f8f9fa !important;
        padding: 5rem 0 !important;
        position: relative;
    }

        .bg-light h2 {
            color: #1e293b;
            font-weight: 800;
            font-size: 2.8rem;
            margin-bottom: 3rem;
            text-align: center;
            animation: fadeIn 1s ease-out forwards;
            opacity: 0;
        }

    /* Product Cards Staggered Animation */
    .product-card {
        border-radius: 15px;
        overflow: hidden;
        transition: all 0.3s ease;
        height: 100%;
        background: white;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.08);
        opacity: 0;
        transform: translateY(30px);
        animation: cardAppear 0.8s ease-out forwards;
    }

    @@keyframes cardAppear {
        0% {
            opacity: 0;
            transform: translateY(30px);
        }

        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Stagger animation delays for product cards */
    .product-card:nth-child(1) {
        animation-delay: 0.1s;
    }

    .product-card:nth-child(2) {
        animation-delay: 0.2s;
    }

    .product-card:nth-child(3) {
        animation-delay: 0.3s;
    }

    .product-card:nth-child(4) {
        animation-delay: 0.4s;
    }

    .product-card:nth-child(5) {
        animation-delay: 0.5s;
    }

    .product-card:nth-child(6) {
        animation-delay: 0.6s;
    }

    .product-card:nth-child(7) {
        animation-delay: 0.7s;
    }

    .product-card:nth-child(8) {
        animation-delay: 0.8s;
    }

    .product-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
    }

    .product-card .card-img-top {
        height: 250px;
        object-fit: cover;
        transition: transform 0.5s ease;
    }

    .product-card:hover .card-img-top {
        transform: scale(1.05);
    }

    .product-card .card-body {
        padding: 1.5rem;
        text-align: center;
    }

    .product-card .card-title {
        font-size: 1.2rem;
        font-weight: 700;
        color: #1e293b;
        margin-bottom: 0.8rem;
        height: 56px;
        overflow: hidden;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
    }

    .product-card .text-primary {
        color: #059669 !important;
        font-weight: 800;
        font-size: 1.4rem;
        margin-bottom: 0.5rem;
    }

    .product-card .text-muted.small {
        color: #64748b !important;
        background: rgba(99, 102, 241, 0.1);
        padding: 0.4rem 0.8rem;
        border-radius: 20px;
        display: inline-block;
        margin-bottom: 1rem;
        font-weight: 600;
    }

    .product-card .btn-outline-primary {
        color: #6366f1;
        border: 2px solid #6366f1;
        border-radius: 10px;
        padding: 0.6rem 1.5rem;
        font-weight: 600;
        transition: all 0.3s ease;
    }

        .product-card .btn-outline-primary:hover {
            background: #6366f1;
            color: white;
            transform: translateY(-2px);
        }

    /* CATEGORIES SECTION - ORIGINAL STYLE with Animation */
    section:not(.bg-light) {
        background: white;
        padding: 5rem 0 !important;
        opacity: 0;
        transform: translateY(30px);
        animation: fadeInUp 1s ease-out 0.5s forwards;
    }

    @@keyframes fadeInUp {
        0% {
            opacity: 0;
            transform: translateY(30px);
        }

        100% {
            opacity: 1;
            transform: translateY(0);
        }
    }

    section:not(.bg-light) h2 {
        color: #1e293b;
        font-weight: 800;
        font-size: 2.8rem;
        margin-bottom: 3rem;
        text-align: center;
        animation: fadeIn 1s ease-out 0.7s forwards;
        opacity: 0;
    }

    /* ORIGINAL CATEGORIES LAYOUT - Simple and Clean */
    .row.text-center {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        margin: -15px;
    }

    .col-md-2.col-6.mb-4 {
        padding: 15px;
        flex: 0 0 16.666667%;
        max-width: 16.666667%;
        opacity: 0;
        transform: translateY(20px);
        animation: fadeInUp 0.6s ease-out forwards;
    }

        /* Stagger animation for category cards */
        .col-md-2.col-6.mb-4:nth-child(1) {
            animation-delay: 0.8s;
        }

        .col-md-2.col-6.mb-4:nth-child(2) {
            animation-delay: 0.9s;
        }

        .col-md-2.col-6.mb-4:nth-child(3) {
            animation-delay: 1.0s;
        }

        .col-md-2.col-6.mb-4:nth-child(4) {
            animation-delay: 1.1s;
        }

        .col-md-2.col-6.mb-4:nth-child(5) {
            animation-delay: 1.2s;
        }

        .col-md-2.col-6.mb-4:nth-child(6) {
            animation-delay: 1.3s;
        }

    .rounded {
        background: white;
        padding: 2rem 1rem !important;
        transition: all 0.3s ease;
        height: 120px;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
        border: 1px solid #e2e8f0;
        border-radius: 10px !important;
    }

        .rounded:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
            border-color: #6366f1;
        }

        .rounded h5 {
            font-size: 1rem;
            font-weight: 600;
            color: #475569;
            margin: 0;
            text-align: center;
        }

    /* Empty State */
    .col-12.text-center .lead {
        color: #64748b;
        font-size: 1.3rem;
        padding: 3rem;
        background: white;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
        max-width: 500px;
        margin: 0 auto;
        animation: fadeIn 1s ease-out;
    }

    /* Responsive Design */
    @@media (max-width: 1200px) {
        .hero h1 {
            font-size: 3rem;
        }

        .col-md-2.col-6.mb-4 {
            flex: 0 0 20%;
            max-width: 20%;
        }
    }

    @@media (max-width: 992px) {
        .hero {
            min-height: 70vh;
        }

            .hero h1 {
                font-size: 2.5rem;
            }

            .hero p.lead {
                font-size: 1.3rem;
            }

        .bg-light h2,
        section:not(.bg-light) h2 {
            font-size: 2.2rem;
        }

        .col-md-2.col-6.mb-4 {
            flex: 0 0 25%;
            max-width: 25%;
        }

        .rounded {
            padding: 1.5rem 1rem !important;
            height: 100px;
        }
    }

    @@media (max-width: 768px) {
        .hero h1 {
            font-size: 2.2rem;
        }

        .hero p.lead {
            font-size: 1.1rem;
        }

        .hero .btn-primary {
            padding: 1rem 2rem;
            font-size: 1.1rem;
        }

        .bg-light,
        section:not(.bg-light) {
            padding: 3rem 0 !important;
        }

        .product-card .card-img-top {
            height: 200px;
        }

        .col-md-2.col-6.mb-4 {
            flex: 0 0 33.333333%;
            max-width: 33.333333%;
        }

        .rounded {
            padding: 1.2rem 0.8rem !important;
        }

            .rounded h5 {
                font-size: 0.9rem;
            }
    }

    @@media (max-width: 576px) {
        .hero h1 {
            font-size: 1.8rem;
        }

        .hero {
            min-height: 60vh;
        }

        .bg-light h2,
        section:not(.bg-light) h2 {
            font-size: 1.8rem;
        }

        .col-md-2.col-6.mb-4 {
            flex: 0 0 50%;
            max-width: 50%;
        }

        .col-12.text-center .lead {
            font-size: 1.1rem;
            padding: 2rem;
        }
    }

    /* Product Grid Layout */
    .row {
        margin: -15px;
    }

    .col-md-3 {
        padding: 15px;
    }

    /* Ensure proper spacing */
    .mb-4 {
        margin-bottom: 1.5rem !important;
    }

    /* Fix for any layout issues */
    .container {
        max-width: 100%;
        padding-left: 15px;
        padding-right: 15px;
    }

    .row {
        margin-left: -15px;
        margin-right: -15px;
    }
</style>

<div class="home-page">
    <!-- Hero Section -->
    <section class="hero text-white text-center py-5"
             style="background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)),
                    url('https://images.unsplash.com/photo-1497633762265-9d179a990aa6?ixlib=rb-4.0.3&auto=format&fit=crop&w=1350&q=80');
                    background-size: cover;">
        <div class="container py-5">
            <h1 class="display-4 fw-bold mb-3">Welcome to Shradha Book Stores</h1>
            <p class="lead mb-4">Books, Notebooks, Stationery & Much More... All at One Place!</p>
            <a href="/Products" class="btn btn-lg btn-primary">Shop Now</a>
        </div>
    </section>

    <!-- Featured Products -->
    <section class="py-5 bg-light">
        <div class="container">
            <h2 class="text-center mb-5">Featured Products</h2>
            <div class="row">
                @if (Model.Any())
                {
                    @foreach (var product in Model)
                    {
                        <div class="col-md-3 col-sm-6 mb-4">
                            <div class="card h-100 border-0 shadow-sm product-card">
                                <img src="@(product.product_image ?? "/images/placeholder.jpg")"
                                     class="card-img-top"
                                     alt="@product.product_name"
                                     style="height: 220px; object-fit: cover;">
                                <div class="card-body text-center">
                                    <h5 class="card-title">@product.product_name</h5>
                                    <p class="text-primary fw-bold">Rs. @product.product_price</p>
                                    <p class="text-muted small">@(product.Category?.Category_Name ?? "Uncategorized")</p>
                                    <a href="/Products/Details/@product.product_id"
                                       class="btn btn-sm btn-outline-primary">View Details</a>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12 text-center">
                        <p class="lead text-muted">No products available at the moment.</p>
                    </div>
                }
            </div>
        </div>
    </section>

    <!-- Categories Section - ORIGINAL SIMPLE DESIGN -->
    <section class="py-5">
        <div class="container">
            <h2 class="text-center mb-5">Categories</h2>
            <div class="row text-center">
                @foreach (var category in ViewBag.Categories)
                {
                    <div class="col-md-2 col-6 mb-4">
                        <div class="p-4 bg-white shadow-sm rounded">
                            <h5>@category.Category_Name</h5>
                        </div>
                    </div>
                }
            </div>
        </div>
    </section>
</div>