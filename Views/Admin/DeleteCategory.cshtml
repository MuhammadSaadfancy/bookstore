@model BookStore.Models.Category
@{
    ViewData["Title"] = "Delete Category";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-exclamation-triangle"></i> Delete Category
                    </h4>
                </div>
                <div class="card-body">
                    <!-- Warning Alert -->
                    <div class="alert alert-danger">
                        <h5><i class="fas fa-exclamation-circle"></i> Warning!</h5>
                        <p class="mb-0">
                            You are about to delete a category. This action cannot be undone.
                        </p>
                    </div>

                    <!-- Category Details -->
                    <div class="card mb-4">
                        <div class="card-header">
                            <h5 class="mb-0">Category Details</h5>
                        </div>
                        <div class="card-body">
                            <table class="table table-bordered">
                                <tr>
                                    <th>Category ID:</th>
                                    <td>@Model.Category_Id</td>
                                </tr>
                                <tr>
                                    <th>Category Name:</th>
                                    <td>
                                        <strong class="text-danger">@Model.Category_Name</strong>
                                    </td>
                                </tr>
                                <tr>
                                    <th>Created:</th>
                                    <td>@DateTime.Now.ToString("dd MMM yyyy")</td>
                                </tr>
                            </table>
                        </div>
                    </div>

                    <!-- Check for Products -->
                    @{
                        var productCount = ViewBag.ProductCount ?? 0;
                    }

                    @if (productCount > 0)
                    {
                        <div class="alert alert-warning">
                            <h5><i class="fas fa-ban"></i> Cannot Delete!</h5>
                            <p>
                                This category has <strong>@productCount product@(productCount != 1 ? "s" : "")</strong>.
                                You must remove or reassign all products before deleting this category.
                            </p>
                            <ul>
                                <li>Products in this category: <strong>@productCount</strong></li>
                                <li>Delete operation is blocked</li>
                            </ul>
                        </div>

                        <div class="d-flex gap-2">
                            <a href="/Admin/Categories" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> Back to Categories
                            </a>
                            <button class="btn btn-danger" disabled>
                                <i class="fas fa-trash"></i> Delete Disabled
                            </button>
                        </div>
                    }
                    else
                    {
                        <!-- Confirmation Message -->
                        <div class="alert alert-info">
                            <p class="mb-0">
                                <i class="fas fa-info-circle"></i>
                                This category has no products. You can safely delete it.
                            </p>
                        </div>

                        <!-- Delete Form -->
                        <form method="post" asp-action="DeleteCategory">
                            <input type="hidden" name="id" value="@Model.Category_Id" />

                            <div class="mb-3">
                                <label class="form-label">
                                    <strong>Type "DELETE" to confirm:</strong>
                                </label>
                                <input type="text" class="form-control"
                                       id="confirmationText"
                                       placeholder="Type DELETE here"
                                       required>
                                <small class="text-muted">
                                    This confirms you understand the action cannot be undone.
                                </small>
                            </div>

                            <div class="d-flex gap-2 mt-4">
                                <a href="/Admin/Categories" class="btn btn-secondary">
                                    <i class="fas fa-times"></i> Cancel
                                </a>
                                <button type="submit"
                                        class="btn btn-danger"
                                        id="deleteBtn"
                                        disabled>
                                    <i class="fas fa-trash"></i> Delete Category
                                </button>
                            </div>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Confirm delete by typing "DELETE"
        document.getElementById('confirmationText').addEventListener('input', function() {
            var deleteBtn = document.getElementById('deleteBtn');
            if (this.value.toUpperCase() === 'DELETE') {
                deleteBtn.disabled = false;
            } else {
                deleteBtn.disabled = true;
            }
        });

        // Form submission confirmation
        document.querySelector('form').addEventListener('submit', function(e) {
            if (!confirm('Are you absolutely sure you want to delete this category?')) {
                e.preventDefault();
            }
        });
    </script>
}