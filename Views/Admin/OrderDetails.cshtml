@model BookStore.Models.Order
@{
    ViewData["Title"] = "Order Details";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Order Details</h1>
        <div class="btn-group">
            <a href="/Admin/Orders" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Back to Orders
            </a>
            <button class="btn btn-primary" onclick="printInvoice()">
                <i class="fas fa-print"></i> Print Invoice
            </button>
        </div>
    </div>

    <!-- Status Update Buttons -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Update Order Status</h5>
                </div>
                <div class="card-body">
                    <div class="btn-group">
                        <!-- Processing Button -->
                        <a href="/Admin/UpdateOrderStatus?orderId=@Model.OrderId&status=Processing"
                           class="btn @(Model.OrderStatus == "Processing" ? "btn-info" : "btn-outline-info")"
                           onclick="return confirm('Mark order #@Model.OrderNumber as Processing?')">
                            <i class="fas fa-cog me-1"></i> Processing
                        </a>

                        <!-- Shipped Button -->
                        <a href="/Admin/UpdateOrderStatus?orderId=@Model.OrderId&status=Shipped"
                           class="btn @(Model.OrderStatus == "Shipped" ? "btn-primary" : "btn-outline-primary")"
                           onclick="return confirm('Mark order #@Model.OrderNumber as Shipped?')">
                            <i class="fas fa-truck me-1"></i> Shipped
                        </a>

                        <!-- Delivered Button -->
                        <a href="/Admin/UpdateOrderStatus?orderId=@Model.OrderId&status=Delivered"
                           class="btn @(Model.OrderStatus == "Delivered" ? "btn-success" : "btn-outline-success")"
                           onclick="return confirm('Mark order #@Model.OrderNumber as Delivered?')">
                            <i class="fas fa-check-circle me-1"></i> Delivered
                        </a>

                        <!-- Cancel Button -->
                        @if (Model.CanCancel && Model.OrderStatus != "Cancelled")
                        {
                            <a href="/Admin/CancelOrder/@Model.OrderId"
                               class="btn btn-outline-danger"
                               onclick="return confirm('Are you sure you want to cancel order #@Model.OrderNumber?')">
                                <i class="fas fa-times-circle me-1"></i> Cancel Order
                            </a>
                        }
                    </div>

                    <!-- Current Status -->
                    <div class="mt-3">
                        <span class="fw-bold">Current Status:</span>
                        @{
                            var statusClass = Model.OrderStatus switch
                            {
                                "Pending" => "badge bg-warning",
                                "Processing" => "badge bg-info",
                                "Shipped" => "badge bg-primary",
                                "Delivered" => "badge bg-success",
                                "Cancelled" => "badge bg-danger",
                                _ => "badge bg-secondary"
                            };
                        }
                        <span class="@statusClass">@Model.OrderStatus</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- Order Information -->
        <div class="col-md-4">
            <div class="card">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><i class="fas fa-info-circle"></i> Order Information</h5>
                </div>
                <div class="card-body">
                    <table class="table table-sm">
                        <tr>
                            <th>Order Number:</th>
                            <td><strong>@Model.OrderNumber</strong></td>
                        </tr>
                        <tr>
                            <th>Order Date:</th>
                            <td>@Model.OrderDate.ToString("dd MMMM yyyy hh:mm tt")</td>
                        </tr>
                        <tr>
                            <th>Order Status:</th>
                            <td>
                                <span class="@statusClass">@Model.OrderStatus</span>
                            </td>
                        </tr>
                        <tr>
                            <th>Payment Type:</th>
                            <td>
                                <span class="badge
                                    @(Model.PaymentType == "Online" ? "bg-success" :
                                                                            Model.PaymentType == "Prepaid" ? "bg-primary" : "bg-warning")">
                                    @Model.PaymentType
                                </span>
                            </td>
                        </tr>
                        <tr>
                            <th>Payment Status:</th>
                            <td>
                                <span class="badge
                                    @(Model.PaymentStatus == "Completed" ? "bg-success" : "bg-warning")">
                                    @Model.PaymentStatus
                                </span>
                            </td>
                        </tr>
                        <tr>
                            <th>Total Amount:</th>
                            <td><strong>Rs. @Model.TotalAmount</strong></td>
                        </tr>
                    </table>
                </div>
            </div>

            <div class="card mt-4">
                <div class="card-header bg-secondary text-white">
                    <h5 class="mb-0"><i class="fas fa-user"></i> Customer Information</h5>
                </div>
                <div class="card-body">
                    <table class="table table-sm">
                        <tr>
                            <th>Name:</th>
                            <td>@Model.CustomerName</td>
                        </tr>
                        <tr>
                            <th>Email:</th>
                            <td><a href="mailto:@Model.CustomerEmail">@Model.CustomerEmail</a></td>
                        </tr>
                        <tr>
                            <th>Phone:</th>
                            <td><a href="tel:@Model.CustomerPhone">@Model.CustomerPhone</a></td>
                        </tr>
                        <tr>
                            <th>Distance:</th>
                            <td>@Model.Distance KM</td>
                        </tr>
                        <tr>
                            <th>Shipping Address:</th>
                            <td>@Model.ShippingAddress</td>
                        </tr>
                    </table>
                </div>
            </div>

            <!-- Order Notes -->
            <div class="card mt-4">
                <div class="card-header bg-warning">
                    <h5 class="mb-0"><i class="fas fa-sticky-note"></i> Order Notes</h5>
                </div>
                <div class="card-body">
                    <form method="post" action="/Admin/UpdateOrderNotes">
                        <input type="hidden" name="orderId" value="@Model.OrderId" />
                        <div class="mb-3">
                            <textarea name="notes" class="form-control" rows="3"
                                      placeholder="Add notes about this order...">@Model.Notes</textarea>
                        </div>
                        <button type="submit" class="btn btn-primary btn-sm">Save Notes</button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Order Items & Summary -->
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="fas fa-shopping-cart"></i> Order Items</h5>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Product</th>
                                    <th>Code</th>
                                    <th>Price</th>
                                    <th>Quantity</th>
                                    <th>Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    int itemCounter = 1;
                                }
                                @foreach (var item in Model.OrderItems)
                                {
                                    <tr>
                                        <td>@itemCounter</td>
                                        <td>@item.ProductName</td>
                                        <td><span class="badge bg-secondary">@item.ProductCode</span></td>
                                        <td>Rs. @item.Price</td>
                                        <td>@item.Quantity</td>
                                        <td>Rs. @(item.Price* item.Quantity)</td>
                                    </tr>
                                    itemCounter++;
                                }
                            </tbody>
                        </table>
                    </div>

                    <!-- Order Summary -->
                    <div class="row mt-4">
                        <div class="col-md-6">
                            <h6><i class="fas fa-map-marker-alt"></i> Shipping Address:</h6>
                            <div class="border p-3 rounded bg-light">
                                @Model.ShippingAddress
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="card border-primary">
                                <div class="card-header bg-light">
                                    <h6 class="mb-0">Order Summary</h6>
                                </div>
                                <div class="card-body">
                                    <table class="table table-sm">
                                        <tr>
                                            <td>Product Total:</td>
                                            <td class="text-end">Rs. @Model.ProductTotal</td>
                                        </tr>
                                        <tr>
                                            <td>Delivery Charges:</td>
                                            <td class="text-end">Rs. @Model.DeliveryCharges</td>
                                        </tr>
                                        @if (Model.CancellationCharges > 0)
                                        {
                                            <tr class="text-danger">
                                                <td>Cancellation Charges:</td>
                                                <td class="text-end">Rs. @Model.CancellationCharges</td>
                                            </tr>
                                        }
                                        <tr class="table-active">
                                            <th>Total Amount:</th>
                                            <th class="text-end">Rs. @Model.TotalAmount</th>
                                        </tr>
                                    </table>
                                </div>
                            </div>

                            <!-- Timeline -->
                            <div class="card mt-3">
                                <div class="card-header bg-light">
                                    <h6 class="mb-0">Order Timeline</h6>
                                </div>
                                <div class="card-body">
                                    <ul class="list-unstyled">
                                        <li>
                                            <i class="fas fa-check-circle text-success me-2"></i>
                                            <strong>Ordered:</strong> @Model.OrderDate.ToString("dd MMM yyyy")
                                        </li>
                                        @if (Model.ShippedDate.HasValue)
                                        {
                                            <li>
                                                <i class="fas fa-truck text-primary me-2"></i>
                                                <strong>Shipped:</strong> @Model.ShippedDate.Value.ToString("dd MMM yyyy")
                                            </li>
                                        }
                                        @if (Model.DeliveredDate.HasValue)
                                        {
                                            <li>
                                                <i class="fas fa-home text-success me-2"></i>
                                                <strong>Delivered:</strong> @Model.DeliveredDate.Value.ToString("dd MMM yyyy")
                                            </li>
                                        }
                                        @if (Model.CancelledDate.HasValue)
                                        {
                                            <li>
                                                <i class="fas fa-times-circle text-danger me-2"></i>
                                                <strong>Cancelled:</strong> @Model.CancelledDate.Value.ToString("dd MMM yyyy")
                                            </li>
                                        }
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function printInvoice() {
            window.print();
        }
    </script>

    <style media="print">
        .sidebar, .navbar-custom, .btn, .card-header.bg-warning, .card-header.bg-info,
        .card-header.bg-success, .card-header.bg-primary, .card-header.bg-secondary {
            display: none !important;
        }

        .main-content {
            margin-left: 0 !important;
            width: 100% !important;
        }

        .card {
            border: 1px solid #000 !important;
        }
    </style>
}