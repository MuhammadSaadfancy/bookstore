@model List<BookStore.Models.Faqs>
@{
    ViewData["Title"] = "Manage FAQs";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Manage FAQs</h1>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Add New FAQ</h5>
                </div>
                <div class="card-body">
                    <form method="post" asp-action="AddFAQ">
                        <div class="mb-3">
                            <label class="form-label">Question *</label>
                            <textarea name="faqs_Question" class="form-control" rows="3" required
                                      placeholder="Enter the question..."></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Answer *</label>
                            <textarea name="faqs_Answer" class="form-control" rows="3" required
                                      placeholder="Enter the answer..."></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="fas fa-plus"></i> Add FAQ
                        </button>
                    </form>
                </div>
            </div>

            <div class="card mt-4">
                <div class="card-header">
                    <h5 class="mb-0">Sample FAQs</h5>
                </div>
                <div class="card-body">
                    <small class="text-muted">You can use these as reference:</small>
                    <ul class="mt-2">
                        <li>Q: What are the delivery charges?</li>
                        <li>Q: How can I track my order?</li>
                        <li>Q: What is your return policy?</li>
                        <li>Q: How do I cancel an order?</li>
                        <li>Q: What payment methods do you accept?</li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">All FAQs (@Model.Count)</h5>
                </div>
                <div class="card-body">
                    @if (Model.Count == 0)
                    {
                        <div class="alert alert-info">
                            No FAQs found. Add your first FAQ.
                        </div>
                    }
                    else
                    {
                        <div class="accordion" id="faqsAccordion">
                            @for (int i = 0; i < Model.Count; i++)
                            {
                                <div class="accordion-item">
                                    <h2 class="accordion-header" id="heading@(i)">
                                        <button class="accordion-button @(i > 0 ? "collapsed" : "")"
                                                type="button" data-bs-toggle="collapse"
                                                data-bs-target="#collapse@(i)">
                                            <strong>Q: </strong> @Model[i].faqs_Question
                                        </button>
                                    </h2>
                                    <div id="collapse@(i)" class="accordion-collapse collapse @(i == 0 ? "show" : "")"
                                         data-bs-parent="#faqsAccordion">
                                        <div class="accordion-body">
                                            <strong>A: </strong> @Model[i].faqs_Answer
                                            <div class="mt-3">
                                                <form method="post" asp-action="DeleteFAQ"
                                                      onsubmit="return confirm('Delete this FAQ?')">
                                                    <input type="hidden" name="id" value="@Model[i].faqs_Id">
                                                    <button type="submit" class="btn btn-danger btn-sm">
                                                        <i class="fas fa-trash"></i> Delete
                                                    </button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>