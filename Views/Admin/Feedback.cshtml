@model List<BookStore.Models.Feedback>
@{
    ViewData["Title"] = "Customer Feedback";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Customer Feedback</h1>
        <span class="badge bg-primary">Total: @Model.Count</span>
    </div>

    @if (Model.Count == 0)
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle"></i> No feedback received yet.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var feedback in Model)
            {
                <div class="col-md-6 mb-4">
                    <div class="card h-100">
                        <div class="card-header d-flex justify-content-between align-items-center">
                            <div>
                                <strong><i class="fas fa-user"></i> @feedback.user_name</strong>
                            </div>
                            <small class="text-muted">
                                <i class="far fa-clock"></i>
                                @DateTime.Now.AddDays(-new Random().Next(0, 30)).ToString("dd MMM yyyy")
                            </small>
                        </div>
                        <div class="card-body">
                            <p class="card-text">@feedback.user_message</p>
                        </div>
                        <div class="card-footer">
                            <button class="btn btn-primary btn-sm reply-btn"
                                    data-id="@feedback.feedback_Id"
                                    data-name="@feedback.user_name">
                                <i class="fas fa-reply"></i> Reply
                            </button>
                            <button class="btn btn-danger btn-sm float-end delete-feedback"
                                    data-id="@feedback.feedback_Id">
                                <i class="fas fa-trash"></i> Delete
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Reply Modal -->
<div class="modal fade" id="replyModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Reply to Feedback</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="replyForm">
                    <input type="hidden" id="feedbackId">
                    <div class="mb-3">
                        <label class="form-label">To:</label>
                        <input type="text" id="customerName" class="form-control" readonly>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Your Reply *</label>
                        <textarea id="replyMessage" class="form-control" rows="4" required
                                  placeholder="Type your reply here..."></textarea>
                    </div>
                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-paper-plane"></i> Send Reply
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Reply button click
            $('.reply-btn').click(function() {
                var feedbackId = $(this).data('id');
                var customerName = $(this).data('name');

                $('#feedbackId').val(feedbackId);
                $('#customerName').val(customerName);
                $('#replyModal').modal('show');
            });

            // Delete feedback
            $('.delete-feedback').click(function() {
                var feedbackId = $(this).data('id');
                if (confirm('Delete this feedback?')) {
                    window.location.href = '/Admin/DeleteFeedback/' + feedbackId;
                }
            });

            // Reply form submit
            $('#replyForm').submit(function(e) {
                e.preventDefault();

                var feedbackId = $('#feedbackId').val();
                var message = $('#replyMessage').val();

                // Here you would typically send an AJAX request
                // For now, we'll just show a success message
                alert('Reply sent successfully! (This would send an email in production)');
                $('#replyModal').modal('hide');
                $('#replyForm')[0].reset();
            });
        });
    </script>
}