@model List<BookStore.Models.Order>
@{
    ViewData["Title"] = "Manage Orders";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Manage Orders</h1>
        <div class="btn-group">
            <a href="#" class="btn btn-outline-success">
                <i class="fas fa-filter"></i> Filter
            </a>
        </div>
    </div>

    <!-- Order Stats -->
    <div class="row mb-4">
        <div class="col-md-2">
            <div class="card bg-primary text-white">
                <div class="card-body text-center py-2">
                    <small>Total Orders</small>
                    <h4 class="mb-0">@Model.Count</h4>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card bg-warning text-white">
                <div class="card-body text-center py-2">
                    <small>Pending</small>
                    <h4 class="mb-0">@Model.Count(o => o.OrderStatus == "Pending")</h4>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card bg-info text-white">
                <div class="card-body text-center py-2">
                    <small>Processing</small>
                    <h4 class="mb-0">@Model.Count(o => o.OrderStatus == "Processing")</h4>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card bg-success text-white">
                <div class="card-body text-center py-2">
                    <small>Delivered</small>
                    <h4 class="mb-0">@Model.Count(o => o.OrderStatus == "Delivered")</h4>
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card bg-danger text-white">
                <div class="card-body text-center py-2">
                    <small>Cancelled</small>
                    <h4 class="mb-0">@Model.Count(o => o.OrderStatus == "Cancelled")</h4>
                </div>
            </div>
        </div>
    </div>

    <!-- Orders Table -->
    <div class="card">
        <div class="card-header">
            <h5 class="mb-0">All Orders</h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover data-table">
                    <thead>
                        <tr>
                            <th>Order #</th>
                            <th>Customer</th>
                            <th>Date</th>
                            <th>Items</th>
                            <th>Total</th>
                            <th>Payment</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model)
                        {
                            <tr>
                                <td>
                                    <strong>@order.OrderNumber</strong>
                                    <br>
                                    <small class="text-muted">ID: @order.OrderId</small>
                                </td>
                                <td>
                                    @order.CustomerName
                                    <br>
                                    <small>@order.CustomerPhone</small>
                                </td>
                                <td>
                                    @order.OrderDate.ToString("dd MMM yy")
                                    <br>
                                    <small>@order.OrderDate.ToString("hh:mm tt")</small>
                                </td>
                                <td>
                                    <span class="badge bg-secondary">@order.OrderItems.Count items</span>
                                </td>
                                <td>
                                    @order.TotalAmount
                                    <br>
                                    <small class="text-muted">Delivery: ₹@order.DeliveryCharges</small>
                                </td>
                                <td>
                                    <span class="badge
                                            @(order.PaymentType == "Online" ? "bg-success" :
                                                                                    order.PaymentType == "Prepaid" ? "bg-primary" : "bg-warning")">
                                        @order.PaymentType
                                    </span>
                                    <br>
                                    <small>@order.PaymentStatus</small>
                                </td>
                                <td>
                                    @{
                                        var statusClass = order.OrderStatus switch
                                        {
                                            "Pending" => "badge-status-pending",
                                            "Processing" => "badge-status-processing",
                                            "Shipped" => "badge-status-shipped",
                                            "Delivered" => "badge-status-delivered",
                                            "Cancelled" => "badge-status-cancelled",
                                            _ => "badge-secondary"
                                        };
                                    }
                                    <span class="badge @statusClass">@order.OrderStatus</span>
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a href="/Admin/OrderDetails/@order.OrderId"
                                           class="btn btn-info" title="View Details">
                                            <i class="fas fa-eye"></i>
                                        </a>

                                        <div class="dropdown">
                                            <button class="btn btn-secondary dropdown-toggle" type="button"
                                                    data-bs-toggle="dropdown">
                                                <i class="fas fa-cog"></i>
                                            </button>
                                            <ul class="dropdown-menu">
                                                <li>
                                                    <a class="dropdown-item" href="#"
                                                       onclick="updateStatus(@order.OrderId, 'Processing')">
                                                        <i class="fas fa-cog text-info"></i> Mark as Processing
                                                    </a>
                                                </li>
                                                <li>
                                                    <a class="dropdown-item" href="#"
                                                       onclick="updateStatus(@order.OrderId, 'Shipped')">
                                                        <i class="fas fa-shipping-fast text-primary"></i> Mark as Shipped
                                                    </a>
                                                </li>
                                                <li>
                                                    <a class="dropdown-item" href="#"
                                                       onclick="updateStatus(@order.OrderId, 'Delivered')">
                                                        <i class="fas fa-check-circle text-success"></i> Mark as Delivered
                                                    </a>
                                                </li>
                                                <li><hr class="dropdown-divider"></li>
                                                @if (order.CanCancel && order.OrderStatus != "Cancelled")
                                                {
                                                    <li>
                                                        <a class="dropdown-item text-danger" href="#"
                                                           onclick="cancelOrder(@order.OrderId)">
                                                            <i class="fas fa-times-circle"></i> Cancel Order
                                                        </a>
                                                    </li>
                                                }
                                            </ul>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function updateStatus(orderId, status) {
            if (confirm('Update order status to ' + status + '?')) {
                window.location.href = '/Admin/UpdateOrderStatus?orderId=' + orderId + '&status=' + status;
            }
        }

        function cancelOrder(orderId) {
            if (confirm('Are you sure you want to cancel this order?')) {
                window.location.href = '/Admin/CancelOrder/' + orderId;
            }
        }

        $(document).ready(function() {
            $('.data-table').DataTable({
                "order": [[2, "desc"]]
            });
        });
    </script>
}