@model List<BookStore.Models.Order>
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <h1 class="mb-4">Dashboard Overview</h1>
    
    <!-- Stats Cards -->
    <div class="row">
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="stat-card bg-primary">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-1">Total Products</h5>
                        <h2>@ViewBag.TotalProducts</h2>
                        <small>In stock</small>
                    </div>
                    <i class="fas fa-box"></i>
                </div>
            </div>
        </div>
        
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="stat-card bg-success">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-1">Total Customers</h5>
                        <h2>@ViewBag.TotalCustomers</h2>
                        <small>Registered users</small>
                    </div>
                    <i class="fas fa-users"></i>
                </div>
            </div>
        </div>
        
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="stat-card bg-info">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-1">Total Orders</h5>
                        <h2>@ViewBag.TotalOrders</h2>
                        <small>All time</small>
                    </div>
                    <i class="fas fa-shopping-cart"></i>
                </div>
            </div>
        </div>
        
        <div class="col-xl-3 col-md-6 mb-4">
            <div class="stat-card bg-warning">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-1">Today's Orders</h5>
                        <h2>@ViewBag.TodayOrders</h2>
                        <small>@DateTime.Today.ToString("dd MMM")</small>
                    </div>
                    <i class="fas fa-calendar-day"></i>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Recent Orders -->
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Recent Orders</h5>
                    <a href="/Admin/Orders" class="btn btn-sm btn-primary">View All</a>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Order #</th>
                                    <th>Customer</th>
                                    <th>Date</th>
                                    <th>Amount</th>
                                    <th>Status</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var order in Model)
                                {
                                    <tr>
                                        <td>
                                            <strong>@order.OrderNumber</strong>
                                            <br>
                                            <small class="text-muted">@order.OrderItems.Count items</small>
                                        </td>
                                        <td>@order.CustomerName</td>
                                        <td>@order.OrderDate.ToString("dd MMM yy")</td>
                                        <td>₹@order.TotalAmount</td>
                                        <td>
                                            @{
                                                var statusClass = order.OrderStatus switch
                                                {
                                                    "Pending" => "badge-status-pending",
                                                    "Processing" => "badge-status-processing",
                                                    "Shipped" => "badge-status-shipped",
                                                    "Delivered" => "badge-status-delivered",
                                                    "Cancelled" => "badge-status-cancelled",
                                                    _ => "badge-secondary"
                                                };
                                            }
                                            <span class="badge @statusClass">@order.OrderStatus</span>
                                        </td>
                                        <td>
                                            <a href="/Admin/OrderDetails/@order.OrderId" class="btn btn-sm btn-info">
                                                <i class="fas fa-eye"></i> View
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Quick Actions -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Quick Actions</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3 mb-3">
                            <a href="/Admin/AddProduct" class="btn btn-primary w-100 py-3">
                                <i class="fas fa-plus fa-2x mb-2"></i><br>
                                Add Product
                            </a>
                        </div>
                        <div class="col-md-3 mb-3">
                            <a href="/Admin/Products" class="btn btn-success w-100 py-3">
                                <i class="fas fa-box fa-2x mb-2"></i><br>
                                Manage Products
                            </a>
                        </div>
                        <div class="col-md-3 mb-3">
                            <a href="/Admin/Orders" class="btn btn-info w-100 py-3">
                                <i class="fas fa-shopping-cart fa-2x mb-2"></i><br>
                                View Orders
                            </a>
                        </div>
                        <div class="col-md-3 mb-3">
                            <a href="/Admin/Customer" class="btn btn-warning w-100 py-3">
                                <i class="fas fa-users fa-2x mb-2"></i><br>
                                View Customers
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Dashboard specific scripts
            console.log("Dashboard loaded");
        });
    </script>
}