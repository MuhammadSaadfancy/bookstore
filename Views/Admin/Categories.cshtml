@model List<BookStore.Models.Category>
@{
    ViewData["Title"] = "Manage Categories";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Manage Categories</h1>
    </div>

    <div class="row">
        <div class="col-md-4">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Add New Category</h5>
                </div>
                <div class="card-body">
                    <form method="post" asp-action="AddCategory">
                        <div class="mb-3">
                            <label class="form-label">Category Name *</label>
                            <input type="text" name="Category_Name" class="form-control" required
                                   placeholder="e.g., Books, Stationery, etc.">
                        </div>
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="fas fa-plus"></i> Add Category
                        </button>
                    </form>
                </div>
            </div>

            <div class="card mt-4">
                <div class="card-header">
                    <h5 class="mb-0">Statistics</h5>
                </div>
                <div class="card-body">
                    <p>Total Categories: <strong>@Model.Count</strong></p>
                    @foreach (var cat in Model)
                    {
                        var productCount = ViewBag.ProductCounts?[cat.Category_Id] ?? 0;
                        <div class="d-flex justify-content-between mb-2">
                            <span>@cat.Category_Name</span>
                            <span class="badge bg-info">@productCount products</span>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-8">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">All Categories</h5>
                </div>
                <div class="card-body">
                    @if (Model.Count == 0)
                    {
                        <div class="alert alert-info">
                            No categories found. Add your first category.
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Category Name</th>
                                        <th>Created</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var category in Model)
                                    {
                                        <tr>
                                            <td>@category.Category_Id</td>
                                            <td>
                                                <strong>@category.Category_Name</strong>
                                            </td>
                                            <td>
                                                <small class="text-muted">N/A</small>
                                            </td>
                                            <td>
                                                <button onclick="deleteCategory(@category.Category_Id, '@category.Category_Name')"
                                                        class="btn btn-danger btn-sm">
                                                    <i class="fas fa-trash"></i> Delete
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function deleteCategory(id, name) {
            if (confirm('Delete category "' + name + '"? This action cannot be undone.')) {
                window.location.href = '/Admin/DeleteCategory/' + id;
            }
        }
    </script>
}